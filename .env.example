# ============================================================
# Job Search AI Agent - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual API keys.
# NEVER commit the .env file to version control!

# Google Gemini API Key (https://aistudio.google.com)
GOOGLE_API_KEY=your_google_api_key_here

# Adzuna Job Search API (https://developer.adzuna.com)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# Proxycurl LinkedIn API (https://nubela.co/proxycurl/)
# Used by the autonomous agent to extract and summarize LinkedIn profiles
PROXYCURL_API_KEY=your_proxycurl_api_key
